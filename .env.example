APP_NAME="CGL ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC
APP_PREVIOUS_KEYS=

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=erp
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_SSLMODE=prefer
DB_FORWARD_PORT=5432

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
FILESYSTEM_THROW=true
FILESYSTEM_REPORT=true
QUEUE_CONNECTION=database
QUEUE_AFTER_COMMIT=true
DB_QUEUE_CONNECTION=
DB_QUEUE_TABLE=jobs
DB_QUEUE=default
DB_QUEUE_RETRY_AFTER=90
QUEUE_FAILED_DRIVER=database-uuids

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_USERNAME=
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_MAX_RETRIES=3
REDIS_BACKOFF_ALGORITHM=decorrelated_jitter
REDIS_BACKOFF_BASE=100
REDIS_BACKOFF_CAP=1000
REDIS_FORWARD_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

ERP_INVOICE_DEFAULT_DUE_DAYS=30
ERP_INVOICE_OVERDUE_GRACE_DAYS=0
ERP_CREDIT_NOTE_AUTO_ISSUE_LIMIT=100000
ERP_PAYMENT_REFERENCE_REQUIRED_METHODS=
ERP_INVOICE_NUMBER_PREFIX=INV
ERP_INVOICE_NUMBER_PADDING=4
ERP_INVOICE_NUMBER_RESET=yearly
ERP_INVOICE_NUMBER_SEPARATOR=-
ERP_TAX_DEFAULT_COUNTRY=
ERP_TAX_DEFAULT_CODE=STANDARD
ERP_TAX_DEFAULT_LABEL="Standard tax profile"
ERP_TAX_DEFAULT_RATE=0
ERP_TAX_DEFAULT_MODE=exclusive
ERP_QUOTE_ACCEPTANCE_GRACE_DAYS=0
ERP_EXPENSE_AUTO_APPROVE_LIMIT=250000
ERP_APPROVAL_BULK_LIMIT=10
ERP_PROJECT_AUTO_APPROVE_STATUSES=planned,on_hold
ERP_DOCUMENTS_DISK=local
ERP_DOCUMENTS_DIRECTORY=attachments
ERP_DOCUMENTS_MAX_UPLOAD_KB=10240
ERP_DOCUMENTS_QUOTA_MB=200
ERP_DOCUMENTS_DOWNLOAD_URL_TTL=30
ERP_DOCUMENTS_ALLOWED_EXTENSIONS=pdf,doc,docx,xls,xlsx,csv,jpg,jpeg,png,zip,txt
ERP_REPORT_RETENTION_DAYS=30
ERP_AUDIT_RETENTION_DAYS=365
ERP_BACKUPS_DISK=local
ERP_BACKUPS_DIRECTORY=backups
ERP_BACKUPS_RETENTION_DAYS=14
ERP_FAILED_JOBS_ALERT_THRESHOLD=5
ERP_BACKUPS_STALE_AFTER_HOURS=24
ERP_API_TOKEN_TTL_DAYS=365
ERP_REQUIRE_COMPANY_CONTEXT_IN_CONSOLE=false
ERP_LOG_MISSING_COMPANY_CONTEXT=true
ERP_PORTAL_TOKEN_TTL_DAYS=180
ERP_PDF_PAPER=a4
ERP_PDF_ORIENTATION=portrait
ERP_PDF_DEFAULT_FONT="DejaVu Sans"
ERP_PDF_DPI=120
ERP_PDF_FONT_SUBSETTING=false
ERP_PDF_COMPACT_WHEN_POSSIBLE=true
ERP_PDF_COMPACT_MAX_ITEMS=6
ERP_PDF_COMPACT_MAX_NOTES_LENGTH=500
ERP_APP_EDITION=full
ERP_SIMPLE_ENABLED_MODULES=dashboard,quotes,invoices,payments,expenses

CROMMIX_CORE_ENABLED=true
CROMMIX_SUPPORT_ENABLED=true
CROMMIX_SAAS_ENABLED=false
CROMMIX_BLOG_ENABLED=false
CROMMIX_HR_ENABLED=false
CROMMIX_PAYROLL_ENABLED=false
CROMMIX_CRM_ENABLED=false
CROMMIX_INVENTORY_ENABLED=false
CROMMIX_PROCUREMENT_ENABLED=false
CROMMIX_POS_ENABLED=false

VITE_APP_NAME="${APP_NAME}"

# Initial company created by the database seeder.
# COMPANY_SLUG defaults to a slugified version of COMPANY_NAME.
COMPANY_NAME="My Company"
COMPANY_SLUG=my-company
COMPANY_EMAIL=contact@example.com
COMPANY_CURRENCY=FCFA

# Initial admin account created by the database seeder.
# ADMIN_PASSWORD is required in production. In other environments it defaults
# to "password" when left blank.
# This default is for local development only.
ADMIN_NAME="Super Admin"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password

GOWA_BASE_URL=https://gowa.crommixmali.com
GOWA_USERNAME=
GOWA_PASSWORD=
GOWA_TIMEOUT=30
